# Database (Railway will set DATABASE_URL automatically)
DATABASE_URL=postgresql://abhyuday@localhost:5432/paper_trading
REDIS_URL=redis://localhost:6379

# SolanaTracker API
SOLANA_TRACKER_API_KEY=23d194ff-5e9a-44ad-8f62-412bb645b577
SOLANA_TRACKER_BASE_URL=https://data.solanatracker.io

# JWT
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_EXPIRES_IN=7d

# Backend (Railway will set PORT automatically)
BACKEND_PORT=4000
BACKEND_HOST=0.0.0.0

# Frontend (set NEXT_PUBLIC_BACKEND_URL to Railway backend URL)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Paper Trading Config
DEFAULT_PAPER_BALANCE=10000
SLIPPAGE_MIN=0.0005
SLIPPAGE_MAX=0.003
TRADE_FEE=0.001

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Railway Deployment Notes:
# - DATABASE_URL: Set automatically by Railway PostgreSQL
# - REDIS_URL: Set automatically by Railway Redis (add Redis addon)
# - PORT: Set automatically by Railway (don't set BACKEND_PORT)
# - NEXT_PUBLIC_BACKEND_URL: Set to your Railway backend URL
# - NEXT_PUBLIC_WS_URL: Set to your Railway backend WebSocket URL
# - JWT_SECRET: Generate a secure random string for production
